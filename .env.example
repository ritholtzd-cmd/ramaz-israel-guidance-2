# Copy this file to .env.local and fill in values from your Supabase project.
# Settings → API in the Supabase dashboard.
# Vite only exposes vars prefixed with VITE_ to the browser. NEVER put the
# service_role key here — it stays server-side (Supabase Edge Function secrets).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
